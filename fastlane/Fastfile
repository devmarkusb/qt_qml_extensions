skip_docs

require "pathname"

def repository_root
  File.expand_path("..", __dir__)
end

def repository_path(path)
  pathname = Pathname.new(path)
  return pathname.to_s if pathname.absolute?

  File.expand_path(path, repository_root)
end

def env_truthy?(name, default_value = false)
  value = ENV[name]
  return default_value if value.nil? || value.empty?

  %w[1 true yes y on].include?(value.downcase)
end

def play_package_name
  ENV.fetch("PACKAGE_NAME", "org.cismypa.qtqmlextensionstestapp")
end

def play_json_key
  ENV.fetch("GOOGLE_PLAY_SERVICE_ACCOUNT_JSON_PATH")
end

def play_track
  ENV.fetch("PLAY_TRACK", "production")
end

def store_entry_version_code
  configured_version_code = ENV.fetch("GOOGLE_PLAY_STORE_ENTRY_VERSION_CODE", "").strip
  configured_version_code = ENV.fetch("VERSION_CODE", "").strip if configured_version_code.empty?
  return configured_version_code unless configured_version_code.empty?

  version_codes = Array(google_play_track_version_codes(
    package_name: play_package_name,
    json_key: play_json_key,
    track: play_track
  ))
  UI.user_error!(
    "No version codes found on Google Play track '#{play_track}'. " \
    "Set store_entry_version_code to an existing Play versionCode."
  ) if version_codes.empty?

  version_codes.map(&:to_i).max.to_s
end

def screenshot_host_package_name
  ENV.fetch("SCREENSHOT_HOST_PACKAGE_NAME", "org.cismypa.qtqmlextensionstestapp.screenshots")
end

def screenshot_test_class
  ENV.fetch(
    "SCREENSHOT_TEST_CLASS",
    "org.cismypa.qtqmlextensionstestapp.screenshots.QtQmlExtensionsScreenshotsTest"
  )
end

def screenshot_host_project_dir
  repository_path(ENV.fetch("SCREENSHOT_TEST_PROJECT_DIR", "android-screenshot-tests"))
end

def screenshot_host_apk_path
  File.join(
    screenshot_host_project_dir,
    "screenshot-host",
    "build",
    "outputs",
    "apk",
    "debug",
    "screenshot-host-debug.apk"
  )
end

def screenshot_test_apk_path
  File.join(
    screenshot_host_project_dir,
    "screenshot-host",
    "build",
    "outputs",
    "apk",
    "androidTest",
    "debug",
    "screenshot-host-debug-androidTest.apk"
  )
end

def screenshot_locale
  ENV.fetch("SCREENSHOT_LOCALE", "en-US")
end

def screenshot_device_type
  ENV.fetch("SCREENSHOT_DEVICE_TYPE", "phone")
end

def screenshot_output_directory
  repository_path(ENV.fetch("SCREENSHOT_OUTPUT_DIRECTORY", "fastlane/metadata/android"))
end

def android_target_activity
  ENV.fetch("QT_ANDROID_TARGET_ACTIVITY", "org.qtproject.qt.android.bindings.QtActivity")
end

def android_target_package
  ENV.fetch("QT_ANDROID_TARGET_PACKAGE", play_package_name)
end

def maybe_install_android_target_apk
  target_apk_path = ENV.fetch("QT_ANDROID_APP_APK_PATH", "").strip
  if target_apk_path.empty?
    UI.message("QT_ANDROID_APP_APK_PATH is not set; assuming #{android_target_package} is already installed.")
    return
  end

  target_apk_path = repository_path(target_apk_path)
  UI.user_error!("QT_ANDROID_APP_APK_PATH does not point to an APK: #{target_apk_path}") unless File.file?(target_apk_path)

  UI.message("Installing Qt Android app APK: #{target_apk_path}")
  sh(ENV.fetch("ADB", "adb"), "install", "-r", target_apk_path)
end

def require_apk_file(path, description)
  UI.user_error!("#{description} was not found at #{path}") unless File.file?(path)

  path
end

default_platform(:android)

platform :android do
  desc "Capture repeatable Android screenshots via UI Automator and fastlane screengrab"
  lane :screenshots do
    gradle(
      project_dir: screenshot_host_project_dir,
      gradle_path: "./gradlew",
      tasks: ["assembleDebug", "assembleDebugAndroidTest"]
    )

    screenshot_host_apk = require_apk_file(screenshot_host_apk_path, "Screenshot host APK")
    screenshot_test_apk = require_apk_file(screenshot_test_apk_path, "Screenshot instrumentation APK")

    maybe_install_android_target_apk

    capture_android_screenshots(
      app_apk_path: screenshot_host_apk,
      tests_apk_path: screenshot_test_apk,
      app_package_name: screenshot_host_package_name,
      tests_package_name: "#{screenshot_host_package_name}.test",
      use_tests_in_classes: [screenshot_test_class],
      launch_arguments: [
        "targetPackage #{android_target_package}",
        "targetActivity #{android_target_activity}"
      ],
      locales: [screenshot_locale],
      output_directory: screenshot_output_directory,
      device_type: screenshot_device_type,
      clear_previous_screenshots: env_truthy?("SCREENSHOT_CLEAR_PREVIOUS"),
      use_timestamp_suffix: env_truthy?("SCREENSHOT_TIMESTAMP_SUFFIX")
    )
  end

  desc "Update Google Play store listing metadata and graphics without uploading an app bundle"
  lane :update_store_entry do
    version_code = store_entry_version_code
    UI.message("Using existing Google Play #{play_track} versionCode #{version_code} for store-entry metadata.")

    upload_to_play_store(
      package_name: play_package_name,
      json_key: play_json_key,
      metadata_path: ENV.fetch("SUPPLY_METADATA_PATH", "fastlane/metadata/android"),
      track: play_track,
      version_code: version_code,
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_changelogs: true,
      sync_image_upload: env_truthy?("GOOGLE_PLAY_SYNC_IMAGE_UPLOAD", true),
      validate_only: env_truthy?("GOOGLE_PLAY_VALIDATE_ONLY"),
      changes_not_sent_for_review: env_truthy?("GOOGLE_PLAY_CHANGES_NOT_SENT_FOR_REVIEW")
    )
  end
end
